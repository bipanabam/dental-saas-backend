erDiagram

  TENANT {
    uuid id PK
    string slug UK "URL-safe clinic identifier"
    string name
    string plan "free | starter | pro | enterprise"
    bool is_active
    string country
    string timezone
    string currency
    timestamp created_at
    timestamp updated_at
  }

  USER {
    uuid id PK
    uuid tenant_id FK
    string username UK
    string hashed_password
    string role "SUPERADMIN | ADMIN | DOCTOR | RECEPTIONIST"
    string full_name
    string email
    string phone
    string specialization
    string nmc_reg_no
    string photo_url
    bool notify_appointment
    bool notify_waiting
    bool notify_lab_results
    bool notify_draft_reminder
    bool notify_daily_summary
    bool require_otp
    bool is_active
    timestamp created_at
    timestamp updated_at
  }

  PATIENT {
    uuid id PK
    uuid tenant_id FK
    string patient_code UK "AUTO: TEN-00001"
    string first_name
    string last_name
    string phone
    string email
    date date_of_birth
    string gender
    string blood_group
    string allergies
    string address
    string status "ACTIVE | INACTIVE | BLOCKED"
    bool is_old
    int visit_count
    uuid primary_account_id FK "self-ref for family"
    string family_relation "Spouse | Child | Parent | Other"
    timestamp last_visit_at
    timestamp created_at
    timestamp updated_at
  }

  MEDICAL_RECORD {
    uuid id PK
    uuid patient_id FK
    uuid assigned_doctor_id FK
    string complaints
    string insurance_provider
    string insurance_no
    string emergency_contact_name
    string emergency_contact_no
    string title
    string status
    timestamp created_at
    timestamp updated_at
  }

  APPOINTMENT {
    uuid id PK
    uuid tenant_id FK
    uuid patient_id FK
    uuid doctor_id FK
    timestamp appointment_date
    int duration_minutes
    string status "BOOKED | CONFIRMED | IN_PROGRESS | COMPLETED | NO_SHOW | CANCELLED"
    string type "WALKIN | BOOKED | FOLLOWUP"
    string treatments
    string notes
    int queue_token
    bool is_paid
    float bill_amount
    timestamp checked_in_at
    timestamp checked_out_at
    timestamp created_at
  }

  DIAGNOSIS {
    uuid id PK
    uuid patient_id FK
    uuid appointment_id FK
    string current_complaint
    string past_history
    string medical_history
    string current_history
    string treatment_plan
    string home_exercise
    string icd10_code
    int vas_score
    jsonb tooth_chart "FDI notation: {11:{status,stage}, 36:{status}}"
    string objective_data
    string medicines
    timestamp next_visit_date
    timestamp created_at
    timestamp updated_at
  }

  PROCEDURE {
    uuid id PK
    uuid tenant_id FK
    uuid patient_id FK
    uuid appointment_id FK
    uuid billing_item_id FK
    string name
    string type "RCT | ORTHODONTIC | IMPLANT | CLEANING | CROWN | EXTRACTION | OTHER"
    string description
    float cost
    int stage_number
    int total_stages
    string stage_notes
    string status "PENDING | IN_PROGRESS | COMPLETED | CANCELLED"
    string medicine
    string suggestions
    timestamp procedure_date
    timestamp created_at
    timestamp updated_at
  }

  TREATMENT_PLAN {
    uuid id PK
    uuid patient_id FK
    uuid tenant_id FK
    uuid created_by FK
    string title
    string type "RCT | ORTHODONTIC | IMPLANT | CLEANING | CROWN | BRIDGE | OTHER"
    int total_sessions
    int completed_sessions
    string status "ACTIVE | COMPLETED | PAUSED | CANCELLED"
    text notes
    timestamp start_date
    timestamp end_date
    timestamp created_at
    timestamp updated_at
  }

  INVOICE {
    uuid id PK
    uuid tenant_id FK
    uuid patient_id FK
    uuid appointment_id FK
    string invoice_no UK "INV-2024-00001"
    float subtotal
    float discount_amount
    float discount_pct
    float tax_amount
    float tax_pct
    float total
    float amount_paid
    float amount_due
    string payment_status "UNPAID | PARTIAL | PAID | REFUNDED"
    bool is_vat_invoice
    string approved_by
    timestamp due_date
    timestamp created_at
    timestamp updated_at
  }

  PAYMENT {
    uuid id PK
    uuid invoice_id FK
    uuid tenant_id FK
    float amount
    string mode "CASH | CARD | ESEWA | KHALTI | FONEPAY | BANK_TRANSFER"
    string reference_no
    string notes
    timestamp paid_at
    timestamp created_at
  }

  BILLING_CATALOG {
    uuid id PK
    uuid tenant_id FK
    string name
    string category "CONSULTATION | PROCEDURE | MEDICINE | LAB | OTHER"
    float base_cost
    string description
    bool is_active
    timestamp created_at
    timestamp updated_at
  }

  DOCUMENT {
    uuid id PK
    uuid tenant_id FK
    uuid patient_id FK
    uuid appointment_id FK
    uuid uploaded_by FK
    string type "XRAY | LAB_REPORT | CONSENT | PRESCRIPTION | PHOTO_BEFORE | PHOTO_AFTER | OTHER"
    string file_name
    string file_url "S3 presigned key"
    string mime_type
    bigint file_size_bytes
    string notes
    timestamp created_at
  }

  PRESCRIPTION {
    uuid id PK
    uuid patient_id FK
    uuid appointment_id FK
    uuid doctor_id FK
    uuid tenant_id FK
    jsonb medicines "array of {name, dosage, frequency, duration, notes}"
    text instructions
    timestamp prescribed_at
    timestamp created_at
  }

  SMS_LOG {
    uuid id PK
    uuid tenant_id FK
    uuid patient_id FK
    string type "APPOINTMENT_REMINDER | FOLLOWUP | BIRTHDAY | DUE_PAYMENT | FEEDBACK | COMPLETION"
    string phone_to
    text message_body
    string status "QUEUED | SENT | FAILED | DELIVERED"
    string provider_ref
    timestamp scheduled_at
    timestamp sent_at
    timestamp created_at
  }

  FEATURE_FLAG {
    uuid id PK
    uuid tenant_id FK
    string flag_key "sms_reminders | recall_campaign | vat_invoice | advanced_reports"
    bool is_enabled
    jsonb metadata "extra config per flag"
    timestamp updated_at
  }

  AUDIT_LOG {
    uuid id PK
    uuid tenant_id FK
    uuid user_id FK
    string action "CREATE | UPDATE | DELETE | LOGIN | LOGOUT | EXPORT"
    string module
    string resource_id
    jsonb before_state
    jsonb after_state
    string ip_address
    timestamp created_at
  }

  SYSTEM_SETTINGS {
    uuid id PK
    uuid tenant_id FK
    float appointment_fee
    int default_slot_minutes
    string clinic_name
    string clinic_logo_url
    string clinic_address
    string clinic_phone
    string clinic_email
    string pan_no
    string vat_no
    bool sms_enabled
    string sms_provider
    string sms_api_key
    timestamp updated_at
  }

  QUEUE_TOKEN {
    uuid id PK
    uuid tenant_id FK
    uuid patient_id FK
    uuid appointment_id FK
    int token_number
    string status "WAITING | CALLED | IN_PROGRESS | DONE | SKIPPED"
    date queue_date
    timestamp called_at
    timestamp created_at
  }

